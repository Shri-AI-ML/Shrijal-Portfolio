# EmailJS Credentials Configuration
# Copy this file to .env and replace the values with your actual EmailJS configurations.
# In Vite, environment variables must be prefixed with VITE_ to be exposed to client-side code.

# The Service ID generated for your email service (e.g., Gmail, Outlook)
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id

# The Template ID generated in your EmailJS dashboard
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# The Public Key (formerly User ID) found under Account -> API Keys in EmailJS dashboard
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
